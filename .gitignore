# Data, checkpoints, envs, logs — never commit (live on /scratch on Explorer)
envs/
data/
ckpts/
checkpoints/
*.ckpt
*.pt
*.safetensors
sample_logs/
wandb/
outputs/
watch_folder/

# Run logs (keep curated summaries in LOG.md instead)
logs/
*.log
slurm-*.out

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/

# macOS junk (AppleDouble resource forks + Finder/Spotlight metadata) — never commit
# (Crucial_X9 is a non-native FS, so macOS spawns ._* shadow files constantly)
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
.fseventsd
.DocumentRevisions-V100
.TemporaryItems
.apdisk

# Results: keep small CSV/JSON metrics, ignore large dumps
results/**/*.npy
results/**/*.npz
